# Example environment variables for local development.
# Copy this file to `.env` (not committed) and fill in real values.

# Server
PORT=5000
NODE_ENV=development

# Auth
# JWT_SECRET should be a long, random string. e.g. use a password generator.
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# MongoDB
# Provide your MongoDB connection string. Keep credentials out of source control.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/study-helper?retryWrites=true&w=majority

# LLM (Groq)
# Set this to your Groq API key in the production environment (Railway, etc.).
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
